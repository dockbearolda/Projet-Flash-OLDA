// Placeholder — full schema added in Étape 10
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id           String  @id @default(cuid())
  ref          String  @unique
  supplierRef  String
  name         String
  family       String
  priceAchat   Decimal @db.Decimal(10, 2)
  archived     Boolean @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
