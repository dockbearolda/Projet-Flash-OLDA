// Devis Flash — schéma Prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id           String   @id @default(cuid())
  ref          String   @unique
  supplierRef  String
  name         String
  family       String   // slug de famille (voir modèle Family)
  priceAchat   Decimal  @db.Decimal(10, 2)
  // Prix Chronopost €/pièce propre à la réf (null ⇒ tarif global ; 0 ⇒ offert).
  chronopostPrice Decimal? @db.Decimal(10, 2)
  // Configuration par référence (vide ⇒ « tout »).
  sizes        String[] @default([]) // ['xs','s',...]
  colorIds     String[] @default([]) // ids coloris textile dispo
  bestColorIds String[] @default([]) // ids coloris best-seller (ordre d'affichage)
  archived     Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model TextileColor {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  hex       String
  best      Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FlockColor {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  hex       String?
  special   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Placement {
  id        String   @id @default(cuid())
  slug      String   @unique
  label     String
  zones     String[] // ['coeur', 'dos', ...]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Zone {
  id    String @id @default(cuid())
  slug  String @unique
  label String
  // Legacy single price (qty=1). Kept for back-compat; runtime pricing uses
  // the tiered `salePrices` grid below.
  price Decimal @db.Decimal(10, 2)
  // Tiered sale-price table: [[qtyThreshold, priceHT], ...]
  salePrices Json     @default("[]")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Transport {
  id        String   @id @default(cuid())
  slug      String   @unique
  label     String
  surcharge Decimal  @db.Decimal(10, 2)
  delay     String
  sort      Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Family {
  id        String   @id @default(cuid())
  slug      String   @unique
  label     String
  sort      Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

model Coef {
  id        String   @id @default(cuid())
  threshold Int      @unique
  coef      Decimal  @db.Decimal(6, 4)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Quote {
  id           String      @id // 'DEV-YYYY-NNNN'
  status       String      @default("draft") // draft | sent | archived
  customerJson Json
  transport    String
  revente      Boolean
  linesJson    Json
  qtyTotal     Int
  subtotalHT   Decimal     @db.Decimal(12, 2)
  transportHT  Decimal     @db.Decimal(12, 2)
  tgcaHT       Decimal     @db.Decimal(12, 2)
  totalHT      Decimal     @db.Decimal(12, 2)
  coef         Decimal     @db.Decimal(6, 4)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  deletedAt    DateTime?

  @@index([deletedAt])
  @@index([updatedAt])
}
